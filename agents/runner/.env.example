# agents/runner：本机 Python Runner（示例环境变量）
# 复制为 `.env` 后按需修改（勿提交含密钥的 `.env`）。

# 监听地址（默认仅本机）
# RUNNER_HOST=127.0.0.1

# 监听端口
# RUNNER_PORT=8765

# Node 中间层（apps/api）基址，供 httpx NodeApiClient 使用
RUNNER_NODE_API_BASE=http://127.0.0.1:3000

# 首次使用：在已登录 Web 后拿到 JWT，执行一次（勿把 token 写进仓库）：
#   export RUNNER_REGISTER_ACCESS_TOKEN='你的JWT'
#   cd agents/runner && uv run agents-runner register
# Runner 设备凭证可由 register 子命令自动生成并写入 ~/.agents-runner/device.env
# （无需再手填下列两项；若要用手填可写在本文件并优先于 user 文件，视 env 加载顺序而定）
# RUNNER_DEVICE_KEY=
# RUNNER_DEVICE_SECRET=

# 可选：仅用 CLI 注册时使用（与 --token 二选一）
# RUNNER_REGISTER_ACCESS_TOKEN=

# 日志级别
# RUNNER_LOG_LEVEL=INFO

# 控制台日志：`json` 单行 | `pretty` 多行缩进 JSON | `console` 彩色键值
# RUNNER_LOG_FORMAT=pretty

# 开发时 uvicorn 热重载（可选）
# RUNNER_RELOAD=1

# 一键绑定：浏览器打开的 Web 地址须与此一致（默认与 Vite 5001 对齐）
# RUNNER_SETUP_WEB_ORIGIN=http://127.0.0.1:5001
# RUNNER_SETUP_ALLOW_ORIGINS=http://127.0.0.1:5001,http://localhost:5001
# RUNNER_SETUP_OPEN_BROWSER=1
