# =============================================================================
# apps/agents — 本机 Agent 服务（默认 http://127.0.0.1:3998）
# =============================================================================
#
# 【目录结构 DDD】src/domain | application | infrastructure | interfaces
#
# ┌─ 写入位置 ────────────────────────────────────────────────────────────────
# │ 一键绑定 POST /v1/setup/ingest 会写入：
# │   • 主凭据文件：AGENTS_DEVICE_ENV_PATH（默认 ~/.agents-runner/device.env）
# │     键名：RUNNER_DEVICE_KEY、RUNNER_DEVICE_SECRET、RUNNER_NODE_API_BASE
# │   • 若 AGENTS_SYNC_CREDENTIALS_TO_LOCAL_ENV=true，额外同步本文件内上述三键
# │     （保留其它行与注释，仅 upsert 这三行）
# │ CLI「agents-runner register」同样只写 device.env，不写本文件
# └──────────────────────────────────────────────────────────────────────────
#
# 【服务与 API】
# AGENTS_HOST=127.0.0.1
# AGENTS_PORT=3998
#
# 【控制面 apps/api；可与 device.env 二选一来源】
# RUNNER_NODE_API_BASE=http://127.0.0.1:4999
#
# 【Runner 设备（可选；通常由一键绑定/device.env 注入）】
# RUNNER_DEVICE_KEY=
# RUNNER_DEVICE_SECRET=
#
# 【device 文件路径；留空则用 ~/.agents-runner/device.env】
# AGENTS_DEVICE_ENV_PATH=
#
# 【一键绑定后是否把 RUNNER_* 三键写回本文件；提交前勿设为 true 若含真实密钥】
# AGENTS_SYNC_CREDENTIALS_TO_LOCAL_ENV=false
#
# 【入口对话估算额度】
# AGENTS_ENTRY_CHAT_ROUND_TOKEN_BUDGET=16384
# AGENTS_ENTRY_CHAT_ROUTER_OVERHEAD=512
#
# 【浏览器 CORS，逗号分隔】
# AGENTS_ALLOW_ORIGINS=http://127.0.0.1:5001,http://localhost:5001
#
# 【首次无凭据：是否打开浏览器 local-init】
# AGENTS_SETUP_OPEN_BROWSER=true
# AGENTS_SETUP_WEB_ORIGIN=http://127.0.0.1:5001
