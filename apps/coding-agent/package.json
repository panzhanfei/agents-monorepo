{
  "name": "coding-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@agents/http-errors": "workspace:^",
    "@agents/logger": "workspace:^",
    "@agents/pipeline-core": "workspace:^",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^3.0.5",
    "eslint": "^9.39.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vitest": "^3.0.5"
  }
}
