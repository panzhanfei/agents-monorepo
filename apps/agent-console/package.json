{
  "name": "agent-console",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"tsx watch server/index.ts\" \"vite\"",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "NODE_ENV=production node dist/server/index.js",
    "preview": "vite preview",
    "lint": "eslint src server --max-warnings 0",
    "check-types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@agents/agents-config": "workspace:^",
    "@agents/logger": "workspace:^",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-query": "^5.80.0",
    "@tanstack/react-virtual": "^3.13.0",
    "clsx": "^2.1.1",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.0",
    "three": "^0.170.0",
    "yaml": "^2.8.2",
    "zod": "^4.4.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/vite": "^4.1.18",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^5.4.21"
  }
}
