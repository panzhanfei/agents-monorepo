{
  "name": "api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm --filter @agents/shared-types build && tsc -p tsconfig.json && pnpm exec tsc-alias -p tsconfig.json && node scripts/fix-barrel-imports.mjs",
    "start": "node dist/index.js",
    "worker": "tsx watch src/worker.ts",
    "worker:start": "node dist/worker.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@agents/shared-types": "workspace:*",
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.52.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.17",
    "prisma": "^6.7.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
