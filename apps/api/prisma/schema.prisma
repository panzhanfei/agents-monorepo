generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  PENDING
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  createdAt DateTime @default(now())
  projects  Project[]
  runners   RunnerDevice[]
}

model Project {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  workspaceRoot String
  createdAt     DateTime @default(now())
  tasks         Task[]

  @@index([userId])
}

model RunnerDevice {
  id         String    @id @default(cuid())
  deviceKey  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  tasks      Task[]

  @@index([userId])
}

/// 业务任务：入队前写入 DB，BullMQ 仅携带 taskId / projectId / runnerDeviceKey
model Task {
  id               String     @id @default(cuid())
  taskId           String     @unique @default(uuid())
  projectId        String
  project          Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runnerDeviceId   String
  runnerDevice     RunnerDevice @relation(fields: [runnerDeviceId], references: [id], onDelete: Cascade)
  status           TaskStatus @default(PENDING)
  payload          Json?
  bullmqJobId      String?
  lastError        String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([projectId])
  @@index([runnerDeviceId])
  @@index([status])
}
