DATABASE_URL="postgresql://agents:agents@127.0.0.1:5432/agents_dev?schema=public"
REDIS_URL="redis://127.0.0.1:6379"
JWT_SECRET="change-me-in-local-env-only"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
# Must include the browser origin (Vite dev URL). Match apps/web vite.config server.port and VITE_API_BASE host.
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:5001,http://127.0.0.1:5001"
RUNNER_HEARTBEAT_TTL_SEC="90"
RUNNER_TASK_LEASE_SEC="180"
RUNNER_TASK_DISPATCH_MODE="db-only"
PROCESS_RUNNER_TASKS_IN_WORKER="false"
HTTP_SHUTDOWN_TIMEOUT_MS="30000"
WORKER_CLOSE_TIMEOUT_MS="60000"
ENABLE_DEV_ROUTES="false"
PORT="3000"
