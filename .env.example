# =============================================================================
# agents-monorepo — 环境变量示例
# 复制为 `.env` 后按需填写；含密钥的文件勿提交仓库。
# 与根目录 `agents.config.yaml` 可并存：YAML 适合结构化默认项，本文件适合
# 密钥、机器相关路径与本机覆盖（推荐 Agent 实现为「env 优先于 YAML」）。
# =============================================================================

# -----------------------------------------------------------------------------
# 各 Agent HTTP 端口（也可用专用变量单独覆盖）
# -----------------------------------------------------------------------------
ORCHESTRATOR_PORT=4010
CODING_AGENT_PORT=4020
REVIEW_AGENT_PORT=4030
TEST_AGENT_PORT=4040
OPS_AGENT_PORT=4050
REQUIREMENTS_AGENT_PORT=4060
# 兼容：仅启动 orchestrator 且未设置 ORCHESTRATOR_PORT 时使用
PORT=4010

# -----------------------------------------------------------------------------
# 任务存储（orchestrator MVP：`memory`；后续可接 Prisma + Postgres 等）
# -----------------------------------------------------------------------------
# memory | postgres（未实现，仅占位；实现后替换 ITaskStore 实现类即可）
TASK_STORE_DRIVER=memory

# --- 以下预留：接入 PostgreSQL / Redis / Bull 时启用（当前 MVP 可不配）---
# DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/agents
# REDIS_URL=redis://127.0.0.1:6379

# -----------------------------------------------------------------------------
# 目标项目来源（coding-agent / orchestrator）
#
# TARGET_PROJECT_SOURCE：
#   git   — 有远端仓库：填写 TARGET_GIT_REPO_URL，工作目录一般为 clone 目的地。
#   local — 新项目或无 Git：不要填写远端 URL；客户在本机选一个目录即可（可为空文件夹、
#           尚未 git init、或仅本地仓库）。此时「权威路径」仅为 TARGET_WORKSPACE_PATH。
#
# 实现约定：所有门禁、测试、打包均以 TARGET_WORKSPACE_PATH 为 cwd（local 时常用绝对路径）。
# -----------------------------------------------------------------------------
TARGET_PROJECT_SOURCE=git

# --- git 模式（TARGET_PROJECT_SOURCE=git）---
# 远端仓库 URL（HTTPS 或 SSH）；local 模式请留空
TARGET_GIT_REPO_URL=https://github.com/your-org/your-target-monorepo.git
TARGET_GIT_DEFAULT_BRANCH=main

# --- 工作目录（两种模式必填其一语义）---
# git：clone / pull 的目标目录（相对 agents-monorepo 根或绝对路径）。
# local：客户电脑上的项目根目录，例如：
#   macOS/Linux  /Users/you/Projects/my-new-app
#   Windows      C:\Users\you\Projects\my-new-app
TARGET_WORKSPACE_PATH=./workspace/target-repo

# --- 飞书两阶段（新项目常见）：先本地路径，后补远端仓库 ---
# 客户可能在飞书里发来「本机目录路径」，AgentRunner 仅在当前任务使用该路径（等同动态覆盖
# TARGET_WORKSPACE_PATH）；目录可以尚无 .git。
# 编码 / 审核 / 测试通过后，客户再在飞书发来「远端仓库地址」，orchestrator/coding-agent 再执行
# git init（若需要）、remote add、commit、push 等到该仓库。（凭证仍走机器上的 SSH/https token，勿出现在飞书明文）
#
# 以下为编排侧开关占位（实现时可读 env 或 YAML）：
FEISHU_PARSE_WORKSPACE_PATH_FROM_MESSAGE=true
FEISHU_PARSE_GIT_REMOTE_URL_FROM_MESSAGE=true
# 收到远端 URL 且工作区尚无 remote 时，是否允许自动 git init + remote add（推送仍需凭证就绪）
GIT_AUTO_INIT_WHEN_REMOTE_PROVIDED=false
GIT_REMOTE_NAME=origin

# -----------------------------------------------------------------------------
# 代码审核（review-agent：与 agents.config.yaml 的 review 段叠加）
# 客户可能自行增删改规则文件；建议将「客户规则」放在独立目录并纳入 Git 或由飞书下发后写入该目录。
# -----------------------------------------------------------------------------
# AI 规则 glob；若客户有独立目录可改为例如 ./config/review/**/*.mdc
REVIEW_AIRULES_GLOB=.cursor/rules/**/*.mdc
# 逻辑配置名：与 agents.config.yaml review.profiles 中 key 对应（便于多套规则切换）
REVIEW_RULES_PROFILE=default
# 客户可写规则根目录（cursor 规则片段、补充 mdc、自定义 blocking 清单等；实现侧应优先 merge 再评审）
REVIEW_CUSTOM_RULES_DIR=./config/review-custom
# 每次审核任务启动前重新从磁盘加载规则（客户改文件后无需重启 Agent）
REVIEW_RULES_RELOAD_EACH_RUN=true
# 额外参与评审的配置文件列表（逗号分隔）
REVIEW_CONFIG_FILES=agents.config.yaml,knip.json,turbo.json,package.json
# 确定性 blocking 门禁（在调用 LLM 前执行；整条字符串由 shell 解析，cwd=TARGET_WORKSPACE_PATH）
REVIEW_BLOCKING_COMMAND=pnpm run lint && pnpm run check-types

# -----------------------------------------------------------------------------
# 打包 / 产物目录（ops-agent：本地构建产出与待同步目录）
# 按目标仓库实际调整，例如 Next standalone：apps/main-next/.release
# -----------------------------------------------------------------------------
PACK_BUILD_OUTPUT_DIR=
PACK_ARTIFACT_LOCAL_DIR=./artifacts/release
PACK_STAGING_DIR=./artifacts/staging

# -----------------------------------------------------------------------------
# 服务器连接（运维发布；密码/密钥仅放本机 .env）
# -----------------------------------------------------------------------------
DEPLOY_SSH_HOST=
DEPLOY_SSH_USER=
DEPLOY_SSH_PORT=22
DEPLOY_REMOTE_PATH=/srv/your-app
# DEPLOY_SSH_KEY_PATH=
# DEPLOY_BASTION_HOST=
# DEPLOY_REMOTE_RESTART_CMD=  例：pm2 reload ecosystem.config.cjs

# -----------------------------------------------------------------------------
# 发包前备份与回滚（ops-agent；在「同步新产物」之前对远端部署目录做快照）
# -----------------------------------------------------------------------------
# 是否在发布步骤前创建远端目录备份（tar/rsync 快照等，由生成脚本具体实现）
OPS_BACKUP_BEFORE_DEPLOY=true
# 远端备份父目录（其下按时间戳或 release id 分子目录）
OPS_BACKUP_REMOTE_PARENT=/srv/backups/your-app
# 保留最近 N 份备份；超出则删最旧（实现侧需防误删）
OPS_BACKUP_KEEP_REVISIONS=5
# 可选：备份成功后再发布；失败则中止发布
OPS_ABORT_PUBLISH_IF_BACKUP_FAILS=true
# 回滚：将 DEPLOY_REMOTE_PATH 指回某一备份快照或执行生成脚本 rollback.sh（见 agents.config.yaml）
OPS_ROLLBACK_SCRIPT_NAME=rollback.sh
# 飞书触发「回滚到上一版本」等意图时是否允许自动执行（建议生产默认 false，需人工确认）
OPS_ROLLBACK_REQUIRE_CONFIRM=true

# -----------------------------------------------------------------------------
# 服务器环境 / 服务 / 端口（ops-agent：经 SSH 只读采集，供发布前检查与写入报告）
# -----------------------------------------------------------------------------
# 期望关注或需预检监听的端口（逗号分隔）；用于对照 ss 输出是否被占用、是否与预期服务一致
OPS_PROBE_LISTEN_PORTS=80,443,3000,4000
# 是否在远端执行 `ss -lntp`（或 Linux 可用 `ss`；无则降级 netstat）
OPS_PROBE_RUN_SS_LNTP=true
# 是否采集 `uname -a`、可用内存、磁盘（df -h）等摘要
OPS_PROBE_RUN_HOST_INFO=true
# 逗号分隔的 systemd 单元名，执行 systemctl status --no-pager（只读）
OPS_PROBE_SYSTEMD_UNITS=
# 是否执行 docker ps --format ...（需要远端有 docker 权限）
OPS_PROBE_DOCKER_PS=false

# -----------------------------------------------------------------------------
# 敏感操作验证码（静态口令）
# 默认在 `agents.config.yaml` → `security.verificationCode.staticCode` 配置；
# 若设置本变量则优先使用（适合生产不把口令放进 YAML）。
# 客户在飞书发起发包 / 回滚 / 改审核或部署相关配置时，消息正文须包含同一串字符。
# -----------------------------------------------------------------------------
VERIFY_CODE=

# -----------------------------------------------------------------------------
# 生成的「打包运维脚本」（由 ops-agent 根据：目标仓库依赖/环境 + 服务器画像生成）
# 建议将 .agents/generated 纳入 Git 或由 CI 校验，避免手改遗忘。
#
# 约定：每次进入「打包运维环境」前做一次指纹对比，若下列任一项变化，应视为
# 「生成脚本可能过期」，需重新扫描并更新生成物（或阻止发布）：
#   - 锁文件（pnpm-lock.yaml / package-lock.json 等）、Node/pnpm 版本要求
#   - 服务器 OS、已装运行时、反向代理/进程管理方式（systemd/pm2/docker）
#   - PACK_BUILD_OUTPUT_DIR / DEPLOY_REMOTE_PATH 等路径变更
# 具体哈希字段写入 AGENTS_OPS_MANIFEST（由 ops-agent 维护）。
# -----------------------------------------------------------------------------
AGENTS_GENERATED_OPS_DIR=.agents/generated
AGENTS_OPS_MANIFEST=.agents/generated/manifest.json
# 若为 true，manifest 与当前指纹不一致时禁止执行生成脚本以外的发布步骤（推荐生产）
AGENTS_OPS_ENFORCE_MANIFEST_FINGERPRINT=false

# -----------------------------------------------------------------------------
# 大模型（本地 / OpenAI 兼容 HTTP；coding-agent、review-agent 可共用）
# -----------------------------------------------------------------------------
LLM_PROVIDER=local
# Ollama OpenAI 兼容示例：http://127.0.0.1:11434/v1
# LM Studio 示例：http://127.0.0.1:1234/v1
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen2.5-coder:latest
# 本地常为空；兼容云厂商时需填写
LLM_API_KEY=
LLM_TIMEOUT_MS=120000

# -----------------------------------------------------------------------------
# 飞书（orchestrator）
# -----------------------------------------------------------------------------
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_ENCRYPT_KEY=
