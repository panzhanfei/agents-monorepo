{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "PORT",
    "ORCHESTRATOR_PORT",
    "CODING_AGENT_PORT",
    "REVIEW_AGENT_PORT",
    "TEST_AGENT_PORT",
    "OPS_AGENT_PORT",
    "REQUIREMENTS_AGENT_PORT",
    "TASK_STORE_DRIVER",
    "LLM_PROVIDER",
    "LLM_BASE_URL",
    "LLM_MODEL",
    "REQUIREMENTS_LLM_MODEL",
    "REVIEW_LLM_MODEL",
    "LLM_API_KEY",
    "LLM_TIMEOUT_MS",
    "REQUIREMENTS_LLM_MAX_RETRIES",
    "REQUIREMENTS_AGENT_INTERNAL_TOKEN",
    "REQUIREMENTS_AGENT_BASE_URL",
    "REQUIREMENTS_AGENT_HTTP_TIMEOUT_MS",
    "TARGET_WORKSPACE_PATH",
    "AGENTS_CONFIG_PATH",
    "PIPELINE_FULL_TEST_COMMAND",
    "REVIEW_RULES_PROFILE",
    "REVIEW_AIRULES_GLOB",
    "REVIEW_CUSTOM_RULES_DIR",
    "REVIEW_CONFIG_FILES",
    "REVIEW_BLOCKING_COMMAND",
    "REVIEW_GATE_TIMEOUT_MS",
    "REVIEW_SKIP_LLM",
    "REVIEW_LLM_MAX_RETRIES",
    "REVIEW_RULES_MAX_CHARS",
    "REVIEW_AGENT_BASE_URL",
    "REVIEW_AGENT_HTTP_TIMEOUT_MS",
    "REVIEW_AGENT_INTERNAL_TOKEN",
    "TEST_GATE_TIMEOUT_MS",
    "TEST_AGENT_BASE_URL",
    "TEST_AGENT_HTTP_TIMEOUT_MS",
    "TEST_AGENT_INTERNAL_TOKEN",
    "CI",
    "NODE_ENV",
    "E2E_BASE_URL",
    "E2E_ORCHESTRATOR_URL",
    "E2E_SKIP_WEB_SERVER"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "**/vitest.config.ts"]
    },
    "test:coverage": {
      "inputs": ["$TURBO_DEFAULT$", "**/vitest.config.ts"]
    },
    "e2e": {
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", "e2e/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
