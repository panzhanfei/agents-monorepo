{
  "name": "agents-monorepo",
  "private": true,
  "scripts": {
    "prepare": "turbo run build --filter='@agents/*'",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "knip": "knip --no-config-hints --exclude exports,types,nsExports,nsTypes,enumMembers,classMembers,duplicates",
    "e2e": "pnpm --filter e2e test",
    "e2e:ui": "pnpm --filter e2e test:ui"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.5",
    "knip": "^5.62.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.0",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
