{
  "name": "agents-monorepo",
  "private": true,
  "scripts": {
    "prepare": "turbo run build --filter='@agents/*'",
    "build": "turbo run build",
    "dev": "bash scripts/dev-with-ngrok.sh",
    "dev:no-tunnel": "turbo run dev",
    "dev:feishu-min": "bash scripts/dev-feishu-min.sh",
    "dev:feishu-min:ngrok": "bash scripts/dev-with-ngrok.sh feishu-min",
    "smoke:feishu": "bash scripts/smoke-feishu-webhook.sh",
    "verify:feishu:requirements": "bash scripts/verify-feishu-requirements-chain.sh",
    "dev:orchestrator:ngrok": "bash scripts/dev-with-ngrok.sh orchestrator",
    "logs": "bash scripts/logs.sh",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "knip": "knip --no-config-hints --exclude exports,types,nsExports,nsTypes,enumMembers,classMembers,duplicates",
    "e2e": "pnpm --filter e2e test",
    "e2e:ui": "pnpm --filter e2e test:ui"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.5",
    "knip": "^5.62.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.0",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
